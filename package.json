{
	"name": "obsidian-ai-writing-buddy",
	"version": "1.0.0",
	"description": "An Obsidian writing assistant for drafting, rewriting, reviewing, and safely applying AI-generated text to notes.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"check:deploy": "npm run lint && npm run build && npm run deploy",
		"lint": "eslint .",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-to-vault.ps1",
		"dev": "node esbuild.config.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:typecheck": "tsc -p tsconfig.test.json --noEmit --skipLibCheck"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.43",
		"@vitest/coverage-v8": "^4.1.8",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@webreflection/sql.js": "^0.3.4",
		"obsidian": "latest",
		"sql.js": "^1.14.1"
	}
}
